{
  "name": "blinenote-app",
  "version": "1.0.0",
  "description": "BLineNote - Aplikasi Catatan Suara AI",
  "main": "server.js",
  "scripts": {
    "build": "npm install --prefer-offline --no-audit --progress=false && npx tailwindcss -i ./css/styles.css -o ./public/css/styles.css --minify",
    "dev": "npx tailwindcss -i ./css/styles.css -o ./public/css/styles.css --watch",
    "start": "echo 'Static site ready'"
  },
  "keywords": [
    "voice-notes",
    "ai",
    "firebase",
    "web-app",
    "progressive-web-app"
  ],
  "author": "BLineNote Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/username/blinenote"
  },
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5"
  }
}
