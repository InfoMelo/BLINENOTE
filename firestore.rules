rules_version = '2';

// ================================
// BLineNote - Firestore Security Rules
// ================================
// 
// PENTING: Deploy rules ini ke Firebase Console
// Cara: Firebase Console → Firestore Database → Rules → Copy paste → Publish
//
// Rules ini memastikan:
// 1. User hanya bisa akses data mereka sendiri
// 2. Data size terbatas (prevent abuse)
// 3. Validasi data structure sebelum write
// 4. Rate limiting via Firebase Auth
// ================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ================================
    // Default: Block All Access
    // ================================
    match /{document=**} {
      allow read, write: if false;
    }
    
    // ================================
    // User Notes Collection
    // ================================
    match /users/{userId}/notes/{noteId} {
      
      // Authentication Check
      function isAuthenticated() {
        return request.auth != null;
      }
      
      // Ownership Check
      function isOwner() {
        return request.auth.uid == userId;
      }
      
      // Document Size Validation (max 1MB per note)
      function isValidSize() {
        return request.resource.size() < 1024 * 1024;
      }
      
      // Data Structure Validation
      function isValidNoteData() {
        let data = request.resource.data;
        
        // Required fields check
        return data.keys().hasAll(['text', 'html', 'timestamp']) &&
               
               // Field type validation
               data.text is string &&
               data.html is string &&
               data.timestamp is string &&
               (data.tag is string || !data.keys().hasAny(['tag'])) &&
               
               // Length validation
               data.text.size() <= 100000 && // Max 100k characters plain text
               data.html.size() <= 200000 && // Max 200k characters HTML
               
               // Tag validation (optional)
               (!data.keys().hasAny(['tag']) || data.tag.size() <= 100);
      }
      
      // READ: User can only read their own notes
      allow read: if isAuthenticated() && isOwner();
      
      // CREATE: User can create notes with valid data
      allow create: if isAuthenticated() && 
                       isOwner() && 
                       isValidSize() &&
                       isValidNoteData();
      
      // UPDATE: User can update their own notes with valid data
      allow update: if isAuthenticated() && 
                       isOwner() && 
                       isValidSize() &&
                       isValidNoteData() &&
                       // Prevent timestamp manipulation on updates
                       request.resource.data.timestamp == resource.data.timestamp;
      
      // DELETE: User can delete their own notes
      allow delete: if isAuthenticated() && isOwner();
    }
    
    // ================================
    // User Metadata Collection (for future use)
    // ================================
    match /users/{userId} {
      
      // Read own user document
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Write own user document (with validation)
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.size() < 100000; // Max 100KB user metadata
    }
    
    // ================================
    // Backup Collection (for future backup features)
    // ================================
    match /users/{userId}/backups/{backupId} {
      
      // Same ownership rules as notes
      allow read, write: if request.auth != null && 
                            request.auth.uid == userId &&
                            request.resource.size() < 10 * 1024 * 1024; // Max 10MB per backup
    }
  }
}
